# ─── SpamShield Backend Environment Variables ───────────────────
# Copy this file to .env and fill in YOUR values

# MongoDB Atlas connection string
# Get from: Atlas → Connect → Connect your application → Copy URI
# Replace <username>, <password>, <cluster> with your details
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/spamshield?retryWrites=true&w=majority

# JWT secret — make this a long random string (keep it private!)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Server port
PORT=5000

# ─── AWS S3 (Feedback Batch Upload) ──────────────────
# Create an S3 bucket and IAM user with PutObject permission
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
S3_BUCKET_NAME=my-new-training-data

# Number of feedback entries before batch-uploading to S3 (default: 25)
FEEDBACK_BATCH_SIZE=25
